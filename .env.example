# Backend
PORT=3001
NODE_ENV=development

# OpenAI (primary LLM for production)
# Get your API key from https://platform.openai.com/api-keys
# Costs ~$5-10/month for moderate use (50 resumes, 500 job searches)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Ollama (local LLM fallback — used when OPENAI_API_KEY is not set)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB (optional vector DB — disabled if unreachable)
CHROMA_URL=http://localhost:8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Notion (optional - for log syncing)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Playwright
BROWSER_HEADLESS=false
